LOG_LEVEL=INFO
DATABASE_URL=sqlite:///data/crypto_pipeline.db

BITHUMB_SYMBOLS=BTC,ETH,XRP,SOL,SUI
BITHUMB_PUBLIC_API_BASE_URL=https://api.bithumb.com/public
BITHUMB_V1_API_BASE_URL=https://api.bithumb.com/v1
BITHUMB_PUBLIC_TIMEOUT_SECONDS=5
BITHUMB_CANDLE_TIMEOUT_SECONDS=10
BITHUMB_CANDLE_MAX_RETRIES=3
BITHUMB_CANDLE_RETRY_DELAY_SECONDS=1
BITHUMB_LOOP_SLEEP_SECONDS=0.2
BITHUMB_ERROR_SLEEP_SECONDS=5
CANDLE_START_SECOND=0
CANDLE_WINDOW_SECONDS=10
CANDLE_TASKS_PER_LOOP=3
ORDERBOOK_DEPTH_ON=1

BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,SOLUSDT,SUIUSDT
BINANCE_BASE_URL=https://api.binance.com/api/v3
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY_SECONDS=1
BINANCE_UPDATE_INTERVAL_SECONDS=0.1
BINANCE_API_CALL_SLEEP_SECONDS=0.1
BINANCE_SYMBOL_SLEEP_SECONDS=0.5
BINANCE_TRADES_LIMIT=1000
BINANCE_KLINES_LIMIT=1000
BINANCE_ORDERBOOK_LIMIT=100

# Private values are intentionally blank. Never commit real credentials.
ACCOUNT_API_BASE_URL=https://api.bithumb.com
ACCOUNT_ACCESS_VALUE=
ACCOUNT_SIGNING_VALUE=
ACCOUNT_COLLECT_INTERVAL_SECONDS=5
