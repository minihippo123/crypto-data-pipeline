TZ=Asia/Seoul
PYTHONUNBUFFERED=1

DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=change-me
DB_NAME=CryptoDB

BINANCE_BASE_URL=https://api.binance.com/api/v3
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,SUIUSDT,SOLUSDT
BINANCE_INTERVALS=1m,3m,5m,15m,30m,1h
BINANCE_UPDATE_INTERVAL_SEC=0.1
BINANCE_API_CALL_SLEEP_SEC=0.1
BINANCE_SYMBOL_SLEEP_SEC=0.5
BINANCE_TRADES_LIMIT=1000
BINANCE_KLINES_LIMIT=1000
BINANCE_ORDERBOOK_LIMIT=100

BITHUMB_SYMBOLS=BTC,ETH,XRP,SOL,SUI
BITHUMB_PUBLIC_API_BASE_URL=https://api.bithumb.com/public
BITHUMB_V1_API_BASE_URL=https://api.bithumb.com/v1
BITHUMB_PUBLIC_TIMEOUT_SEC=5
BITHUMB_CANDLE_TIMEOUT_SEC=10
BITHUMB_CANDLE_MAX_RETRIES=3
BITHUMB_CANDLE_RETRY_DELAY_SEC=5
BITHUMB_ERROR_SLEEP_SEC=5
RT_LOOP_SLEEP=0.2
CANDLE_START_SEC=0
CANDLE_WINDOW_SEC=10
CANDLE_TASKS_PER_LOOP=3
ORDERBOOK_DEPTH_ON=1

DQ_DEFAULT_MODE=auto
DQ_INCREMENTAL_LOOKBACK_HOURS=12
DQ_DEEP_LOOKBACK_DAYS=7
DQ_BITHUMB_INTERVALS=1m,3m,5m,10m,15m,30m
DQ_CHUNK_DAYS=7
DQ_CHUNK_DAYS_1M=1
DQ_CHUNK_DAYS_DEFAULT=7
DQ_REPAIR_ENABLED=true
DQ_MAX_BACKFILL_RETRIES=3
DQ_API_REQUEST_DELAY_SEC=0.2
DQ_API_TIMEOUT_SEC=10
DQ_API_COUNT_PER_REQUEST=200
DQ_LOCK_TIMEOUT_MINUTES=120
DQ_INDICATOR_WARMUP_CANDLES=120
DQ_INDICATOR_DEPENDENCY_CANDLES=200
DQ_INDICATOR_RECALC_LIMIT_PER_DATASET=5000
DQ_INDICATOR_BATCH_SIZE=500
DQ_INDICATOR_QUEUE_STALE_MINUTES=120
DQ_INDICATOR_QUEUE_MAX_ATTEMPTS=3
DQ_FRESHNESS_MINUTES=1m:5,3m:10,5m:15,10m:20,15m:30,30m:60
