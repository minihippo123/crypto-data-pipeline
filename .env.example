# Copy this file to .env before starting Docker Compose.
# cp .env.example .env

LOG_LEVEL=INFO

# Container process identity used for bind-mounted NAS directories.
# On Synology, run `id` over SSH and set these values to that user's UID/GID.
PUID=1000
PGID=1000

# Database used inside the containers.
# Keep the container path under /app/data so it is persisted by NAS_DATA_DIR.
DATABASE_URL=sqlite:////app/data/crypto_pipeline.db

# Host/NAS directory mounted into /app/data.
# Synology example: /volume1/docker/crypto-data-pipeline/data
# Local default: ./data
NAS_DATA_DIR=./data

# Data-quality execution target.
QUALITY_SYMBOL=BTC
QUALITY_INTERVAL=1m

# Optional generic candle repair endpoint.
# Leave QUALITY_REPAIR_ARGS blank to scan/revalidate without HTTP repair.
# Set QUALITY_REPAIR_ARGS=--repair only when SOURCE_API_BASE_URL provides GET /candles.
QUALITY_REPAIR_ARGS=
SOURCE_API_BASE_URL=
SOURCE_API_TIMEOUT_SECONDS=10

BITHUMB_SYMBOLS=BTC,ETH,XRP,SOL,SUI
BITHUMB_PUBLIC_API_BASE_URL=https://api.bithumb.com/public
BITHUMB_V1_API_BASE_URL=https://api.bithumb.com/v1
BITHUMB_PUBLIC_TIMEOUT_SECONDS=5
BITHUMB_CANDLE_TIMEOUT_SECONDS=10
BITHUMB_CANDLE_MAX_RETRIES=3
BITHUMB_CANDLE_RETRY_DELAY_SECONDS=1
BITHUMB_LOOP_SLEEP_SECONDS=0.2
BITHUMB_ERROR_SLEEP_SECONDS=5
CANDLE_START_SECOND=0
CANDLE_WINDOW_SECONDS=10
CANDLE_TASKS_PER_LOOP=3
ORDERBOOK_DEPTH_ON=1

BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,XRPUSDT,SOLUSDT,SUIUSDT
BINANCE_BASE_URL=https://api.binance.com/api/v3
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY_SECONDS=1
BINANCE_UPDATE_INTERVAL_SECONDS=0.1
BINANCE_API_CALL_SLEEP_SECONDS=0.1
BINANCE_SYMBOL_SLEEP_SECONDS=0.5
BINANCE_TRADES_LIMIT=1000
BINANCE_KLINES_LIMIT=1000
BINANCE_ORDERBOOK_LIMIT=100

# Private account collection is disabled unless the private-account profile is used.
# Never commit real values.
ACCOUNT_API_BASE_URL=https://api.bithumb.com
ACCOUNT_ACCESS_VALUE=
ACCOUNT_SIGNING_VALUE=
ACCOUNT_COLLECT_INTERVAL_SECONDS=5
